{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "jonagoldman/play",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "license": "MIT",
    "authors": [
        {
            "name": "Jona Goldman",
            "email": "jonagoldman@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "deplox/laravel-essentials": "^0.1",
        "deplox/laravel-shield": "^0.1",
        "deplox/laravel-support": "^0.1",
        "laravel/framework": "dev-13.x-opinionated as 13.7.0",
        "laravel/tinker": "^3.0.2",
        "symfony/filesystem": "^8.0.1"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.1.9",
        "fakerphp/faker": "^1.24.1",
        "larastan/larastan": "^3.9.1",
        "laravel/boost": "^2.4.1",
        "laravel/pail": "^1.2.4",
        "laravel/pint": "^1.27.0",
        "laravel/sail": "^1.52.0",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.8.3",
        "pestphp/pest": "^4.3.2",
        "pestphp/pest-plugin-laravel": "^4.0.0",
        "rector/rector": "^2.3.5"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/deplox/laravel-framework"
        },
        {
            "type": "vcs",
            "url": "https://github.com/deplox/laravel-shield.git"
        },
        {
            "type": "vcs",
            "url": "https://github.com/deplox/laravel-support.git"
        },
        {
            "type": "vcs",
            "url": "https://github.com/deplox/laravel-essentials.git"
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "refactor": "rector",
        "stan": [
            "phpstan analyse --memory-limit=2G"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "use-local-deplox": [
            "@php -r \"copy('composer.json', 'composer.json.bak');\"",
            "@composer config repositories.deplox-shield path .deplox-link/laravel-shield",
            "@composer config repositories.deplox-support path .deplox-link/laravel-support",
            "@composer config repositories.deplox-essentials path .deplox-link/laravel-essentials",
            "@composer require deplox/laravel-shield:@dev deplox/laravel-support:@dev deplox/laravel-essentials:@dev --no-update",
            "@composer update deplox/laravel-shield deplox/laravel-support deplox/laravel-essentials"
        ],
        "use-released-deplox": [
            "@php -r \"if (file_exists('composer.json.bak')) { rename('composer.json.bak', 'composer.json'); } else { fwrite(STDERR, \\\"no composer.json.bak — restore manually with: git checkout composer.json composer.lock\\n\\\"); exit(1); }\"",
            "@composer update deplox/laravel-shield deplox/laravel-support deplox/laravel-essentials"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan boost:update --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
